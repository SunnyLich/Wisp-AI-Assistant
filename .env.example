# Copy this file to .env for non-secret config.
# API keys are stored in the OS keychain from Settings, not in this file.

# First-run profile wizard (normally written by the app; all choices can be changed in Settings).
WISP_ONBOARDING_COMPLETE=False
WISP_PROFILE_NAME=
WISP_SETUP_MODE=
WISP_TTS_PREFERENCE=none
WISP_STT_PREFERENCE=none

# LLM (hotkey queries — optimise for low latency)
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192
# Optional fallback priority, one provider:model per line or semicolon separated.
# Example: LLM_FALLBACKS=chatgpt:gpt-5.5; anthropic:claude-sonnet-4-5
# Z.AI / GLM example: LLM_PROVIDER=zai  LLM_MODEL=glm-4.7-flash
# Other native OpenAI-compatible examples: nvidia, sambanova, github_models,
# huggingface, chutes, vercel, fireworks, cohere, ai21, nebius
LLM_FALLBACKS=

# The chat window shares the model above (LLM_PROVIDER / LLM_MODEL) — there is
# no separate chat model. (Legacy CHAT_LLM_* keys are ignored.)

# Optional: force a different model only when tools are active (otherwise the
# model above is used for tool calls too). Leave blank to use LLM_MODEL.
# e.g. TOOL_LLM_MODEL=claude-sonnet-4-5
TOOL_LLM_MODEL=

# Experimental: split one conversational reply into a hidden plan plus a few
# visible small-turn chunks. Disabled by default; tool, file, image, and history
# requests always use the normal reply path.
WISP_PLANNED_CHUNKING=False
WISP_PLANNED_CHUNKING_CHUNKS=3
WISP_PLANNED_CHUNKING_MIN_PROMPT_CHARS=80

# Vision LLM (screenshots + screen-snip queries — must support image input)
# Required to use the snip feature; leave blank to get a helpful error at runtime.
# Recommended: anthropic + claude-opus-4-5  |  or openai + gpt-4o
VISION_LLM_PROVIDER=anthropic
VISION_LLM_MODEL=claude-opus-4-5
VISION_LLM_FALLBACKS=

# TTS provider: cartesia | elevenlabs | openai | openai_compatible | gpt_sovits | kokoro | none
TTS_PROVIDER=none
# Keep False to use TTS only for F7/read-selection-aloud and Test TTS.
# Set True to speak assistant replies automatically as they stream.
TTS_SPEAK_REPLIES=False
CARTESIA_VOICE_ID=your_voice_id_here

# ElevenLabs: voice id is optional (blank = account default voice).
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# OpenAI TTS (reuses your OpenAI API key from Settings).
OPENAI_TTS_VOICE=alloy
OPENAI_TTS_MODEL=gpt-4o-mini-tts

# OpenAI-compatible endpoint (self-hosted Kokoro/LocalAI, Groq, …). Must expose
# an OpenAI-style /audio/speech route that can return response_format=pcm.
# The API key (if the server needs one) is stored in the OS keychain from Settings.
TTS_CUSTOM_BASE_URL=
TTS_CUSTOM_VOICE=
TTS_CUSTOM_MODEL=
TTS_CUSTOM_SAMPLE_RATE=24000

# GPT-SoVITS local API. Start GPT-SoVITS separately with:
#   python api_v2.py -a 127.0.0.1 -p 9880 -c GPT_SoVITS/configs/tts_infer.yaml
# Then point Wisp at the local server and reference voice.
GPT_SOVITS_URL=http://127.0.0.1:9880
GPT_SOVITS_REF_AUDIO_PATH=
GPT_SOVITS_PROMPT_TEXT=
GPT_SOVITS_PROMPT_LANG=en
GPT_SOVITS_TEXT_LANG=en
GPT_SOVITS_SAMPLE_RATE=32000

# Kokoro local TTS. No API key, server, or reference audio needed.
# Install from Settings -> TTS / Voice after selecting TTS_PROVIDER=kokoro.
KOKORO_VOICE=af_heart
KOKORO_LANG_CODE=a
KOKORO_DEVICE=auto
KOKORO_SPEED=1.0
KOKORO_SAMPLE_RATE=24000
TTS_VOLUME=1.0
# Advanced chunking. These are also available under Settings -> TTS / Voice -> Advanced settings.
TTS_READ_ALOUD_MIN_WORDS=50
TTS_READ_ALOUD_MAX_WORDS=110

# Speech-to-text / hold-to-talk transcription
# STT_MODEL tradeoff: base is fast; small improves Mandarin/Cantonese speech; medium is heavier.
# Leave blank if you do not use voice query or dictation.
# Cantonese (yue) is only natively supported by large-v3 — smaller models can't decode it.
STT_MODEL=base
STT_COMPUTE_TYPE=int8
# STT_LANGUAGE: en | zh | yue | es | fr | de | ja | ko | pt | hi | blank for auto-detect.
STT_LANGUAGE=en
# STT_BEAM_SIZE: decoding beam width (1-10). 5 = Whisper default, more accurate; 1 = fastest/greedy.
STT_BEAM_SIZE=5
# STT_DEVICE: cpu | cuda | auto. cuda needs an NVIDIA GPU + CUDA libs and is much
# faster (esp. large-v3); auto uses the GPU when present and falls back to CPU.
STT_DEVICE=auto
# Advanced background STT chunking for long recordings.
STT_BACKGROUND_CHUNK_FIRST_TRIGGER_SECONDS=15.0
STT_BACKGROUND_CHUNK_STEP_SECONDS=10.0
STT_BACKGROUND_CHUNK_LIVE_DELAY_SECONDS=4.5
STT_BACKGROUND_CHUNK_OVERLAP_SECONDS=1.0

# App language: blank = system default; supported values: en, zh, zh-Hant, es, fr.
APP_LANGUAGE=

# Linux floating-overlay backend: auto uses XWayland when available so the
# icon, bubble, and context panel can be positioned precisely. Set wayland to
# opt into the native Qt Wayland backend instead.
WISP_UI_PLATFORM=auto

# Assistant response language: blank = system default, match_user = mirror user's latest request.
# You can also set a language name such as English, Chinese, Chinese (Traditional), Spanish, or French.
ASSISTANT_LANGUAGE=

# Hotkeys
HOTKEY_ADD_CONTEXT=alt+q
HOTKEY_CLEAR_CONTEXT=alt+w
HOTKEY_SNIP=ctrl+alt+q
# Read the currently selected text aloud with TTS. Blank disables this hotkey.
HOTKEY_READ_SELECTION_ALOUD=f7
# Push-to-talk voice query: hold to transcribe speech and ask the assistant.
HOTKEY_VOICE=f9
# Hands-free live voice conversation (Gemini Live). The provider currently uses
# the Google API key configured on the LLM tab.
HOTKEY_VOICE_LIVE=shift+f9
LIVE_VOICE_PROVIDER=google
LIVE_VOICE_MODEL=gemini-3.1-flash-live-preview
LIVE_VOICE_VOICE_NAME=
LIVE_VOICE_HALF_DUPLEX=False
# Push-to-talk dictation: hold to type speech into the focused text field (no assistant).
# Set empty to disable. DICTATE_MODE: raw | llm.
HOTKEY_DICTATE=f8
DICTATE_MODE=raw
# Optional: show transcript candidates before voice query/dictation paste.
VOICE_TRANSCRIPT_CONFIRM=False
# Optional: after F9 transcription, open the intent overlay with the transcript
# in the custom prompt field so context can be chosen per request.
VOICE_REVIEW_TRANSCRIPT=False
VOICE_CONTEXT_AMBIENT=False
VOICE_CONTEXT_DOCUMENTS_MODE=off
VOICE_CONTEXT_BROWSER_MODE=off
VOICE_CONTEXT_MEMORY_MODE=off
VOICE_CONTEXT_SCREENSHOT=off
VOICE_TOOLS=
SNIP_CONTEXT_AMBIENT=False
SNIP_CONTEXT_CLIPBOARD=False
SNIP_CONTEXT_DOCUMENTS=False
SNIP_CONTEXT_DOCUMENTS_MODE=off
SNIP_CONTEXT_BROWSER_MODE=off
SNIP_CONTEXT_GITHUB_MODE=off
SNIP_CONTEXT_MEMORY_MODE=off
SNIP_CONTEXT_SCREENSHOT=off
SNIP_CONTEXT_TOOLS=False
SNIP_FILE_ACCESS=off
SNIP_TOOLS=

# Caller hotkeys
# Context toggles:
#   AMBIENT = active window, URL, clipboard preview, focused element
#   DOCUMENTS = proactively read open supported documents
#   TOOLS = legacy compatibility flag for tool-routed context
#   SCREENSHOT = auto-capture primary monitor when no text is selected
# Default caller hotkeys are platform-specific:
#   Windows: ctrl+q / ctrl+shift+q
#   macOS/Linux: ctrl+alt+space / ctrl+alt+shift+space
CALLER_COUNT=2
CALLER_1_HOTKEY=ctrl+q
CALLER_1_LABEL=General
CALLER_1_PASTE_BACK=False
CALLER_1_CUSTOM_KEY=s
CALLER_1_CUSTOM_LABEL=
CALLER_1_CONTEXT_AMBIENT=False
CALLER_1_CONTEXT_DOCUMENTS=False
CALLER_1_CONTEXT_DOCUMENTS_MODE=off
CALLER_1_CONTEXT_BROWSER_MODE=off
CALLER_1_CONTEXT_GITHUB_MODE=off
CALLER_1_CONTEXT_TOOLS=False
CALLER_1_CONTEXT_MEMORY_MODE=off
# Screenshot context: off | model (model takes one on demand) | auto (always at hotkey time)
CALLER_1_CONTEXT_SCREENSHOT=off
CALLER_2_HOTKEY=ctrl+shift+q
CALLER_2_LABEL=Rewrite & Paste
CALLER_2_PASTE_BACK=True
CALLER_2_CUSTOM_KEY=s
CALLER_2_CUSTOM_LABEL=
CALLER_2_CONTEXT_AMBIENT=False
CALLER_2_CONTEXT_DOCUMENTS=False
CALLER_2_CONTEXT_DOCUMENTS_MODE=off
CALLER_2_CONTEXT_BROWSER_MODE=off
CALLER_2_CONTEXT_GITHUB_MODE=off
CALLER_2_CONTEXT_TOOLS=False
CALLER_2_CONTEXT_MEMORY_MODE=off
CALLER_2_CONTEXT_SCREENSHOT=off

# Context character budgets
CONTEXT_BROWSER_MAX_CHARS=12000
CONTEXT_AMBIENT_DOCUMENT_MAX_CHARS=8000
CONTEXT_TOOL_DOCUMENT_MAX_CHARS=50000
# Legacy script-tool folder. New extensions should use addons/.
TOOL_PLUGIN_DIR=tools/installed

# Memory
# Explicit commands like "remember that..." still save facts when auto mode is off.
MEMORY_LLM_PROVIDER=groq
MEMORY_LLM_MODEL=llama3-8b-8192
# Optional provider:model fallback routes, one per line or ';'-separated.
MEMORY_LLM_FALLBACKS=
MEMORY_AUTO_CONSOLIDATE=False
MEMORY_CONSOLIDATION_INTERVAL=15
MEMORY_TOP_K=3
MEMORY_STM_TOKEN_BUDGET=4000

# App behaviour
TRUST_PRIVACY_MODE=True
DARK_MODE=false
ICON_AUTO_HIDE=false
START_ON_LOGIN=false
CHAT_AUTO_ELABORATE=false
CHAT_ELABORATE_PROMPT=Please elaborate on that.

# GitHub OAuth
# End users should not need these. The app should bundle its OAuth client ID.
# GITHUB_CLIENT_ID is only a developer override.
GITHUB_DEFAULT_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_OAUTH_SCOPES=repo read:user user:email

# GitHub Copilot SDK
# Tokens are saved from Settings -> LLM into the OS keychain, not this file.
# Optional advanced overrides if you run your own Copilot CLI server/binary.
COPILOT_CLI_URL=
COPILOT_CLI_PATH=

# Bubble appearance
ICON_SIZE=60
BUBBLE_WIDTH=340
BUBBLE_LINES=4
BUBBLE_FONT_SIZE=10
BUBBLE_COLOR=#1c1c24dc
BUBBLE_TEXT_COLOR=#e6e6e6
BUBBLE_READ_WORD_COLOR=#4da3ff
BUBBLE_SCROLL_ENABLED=True
BUBBLE_SCROLL_SNAP_ENABLED=True
BUBBLE_SCROLL_SNAP_DELAY_MS=2500
BUBBLE_REVEAL_WPM=170
BUBBLE_HOLD_REVEAL_WPM=480

# Copy this file to .env for non-secret config.
# API keys are stored in the OS keychain from Settings, not in this file.

# LLM (hotkey queries — optimise for low latency)
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192
# Optional fallback priority, one provider:model per line or semicolon separated.
# Example: LLM_FALLBACKS=chatgpt:gpt-5.5; anthropic:claude-sonnet-4-5
LLM_FALLBACKS=

# The chat window shares the model above (LLM_PROVIDER / LLM_MODEL) — there is
# no separate chat model. (Legacy CHAT_LLM_* keys are ignored.)

# Optional: force a different model only when tools are active (otherwise the
# model above is used for tool calls too). Leave blank to use LLM_MODEL.
# e.g. TOOL_LLM_MODEL=claude-sonnet-4-5
TOOL_LLM_MODEL=

# Vision LLM (screenshots + screen-snip queries — must support image input)
# Required to use the snip feature; leave blank to get a helpful error at runtime.
# Recommended: anthropic + claude-opus-4-5  |  or openai + gpt-4o
VISION_LLM_PROVIDER=anthropic
VISION_LLM_MODEL=claude-opus-4-5
VISION_LLM_FALLBACKS=

# TTS provider: cartesia | elevenlabs | none
TTS_PROVIDER=none
CARTESIA_VOICE_ID=your_voice_id_here

# Hotkeys
HOTKEY_ADD_CONTEXT=alt+q
HOTKEY_CLEAR_CONTEXT=alt+w
HOTKEY_SNIP=ctrl+alt+q
SNIP_CONTEXT_AMBIENT=True
SNIP_CONTEXT_DOCUMENTS=False
SNIP_CONTEXT_TOOLS=False

# Caller hotkeys
# Context toggles:
#   AMBIENT = active window, URL, clipboard preview, focused element
#   DOCUMENTS = proactively read open supported documents
#   TOOLS = allow model/tool path to fetch context on demand where supported
#   SCREENSHOT = auto-capture primary monitor when no text is selected
CALLER_COUNT=2
CALLER_1_HOTKEY=ctrl+q
CALLER_1_LABEL=General
CALLER_1_PASTE_BACK=False
CALLER_1_CUSTOM_KEY=s
CALLER_1_CONTEXT_AMBIENT=True
CALLER_1_CONTEXT_DOCUMENTS=True
CALLER_1_CONTEXT_TOOLS=True
# Screenshot context: off | model (model takes one on demand) | auto (always at hotkey time)
CALLER_1_CONTEXT_SCREENSHOT=off
CALLER_2_HOTKEY=ctrl+shift+q
CALLER_2_LABEL=Rewrite & Paste
CALLER_2_PASTE_BACK=True
CALLER_2_CUSTOM_KEY=s
CALLER_2_CONTEXT_AMBIENT=True
CALLER_2_CONTEXT_DOCUMENTS=False
CALLER_2_CONTEXT_TOOLS=False
CALLER_2_CONTEXT_SCREENSHOT=off

# Context character budgets
CONTEXT_BROWSER_MAX_CHARS=4000
CONTEXT_AMBIENT_DOCUMENT_MAX_CHARS=8000
CONTEXT_TOOL_DOCUMENT_MAX_CHARS=50000
TOOL_PLUGIN_DIR=tools/installed

# Memory
# Explicit commands like "remember that..." still save facts when auto mode is off.
MEMORY_LLM_PROVIDER=groq
MEMORY_LLM_MODEL=llama3-8b-8192
# Optional provider:model fallback routes, one per line or ';'-separated.
MEMORY_LLM_FALLBACKS=
MEMORY_AUTO_CONSOLIDATE=False
MEMORY_CONSOLIDATION_INTERVAL=15
MEMORY_TOP_K=3
MEMORY_RELEVANCE_MAX_DISTANCE=0.55
MEMORY_STM_TOKEN_BUDGET=4000

# App behaviour
DARK_MODE=false
ICON_AUTO_HIDE=false
CHAT_AUTO_ELABORATE=false
CHAT_ELABORATE_PROMPT=Please elaborate on that.

# GitHub OAuth
# End users should not need these. The app should bundle its OAuth client ID.
# GITHUB_CLIENT_ID is only a developer override.
GITHUB_DEFAULT_CLIENT_ID=
GITHUB_CLIENT_ID=
GITHUB_OAUTH_SCOPES=repo read:user user:email

# GitHub Copilot SDK
# Tokens are saved from Settings -> LLM into the OS keychain, not this file.
# Optional advanced overrides if you run your own Copilot CLI server/binary.
COPILOT_CLI_URL=
COPILOT_CLI_PATH=

# Bubble appearance
BUBBLE_WIDTH=340
BUBBLE_LINES=3
BUBBLE_COLOR=#1c1c24dc
BUBBLE_TEXT_COLOR=#e6e6e6
BUBBLE_READ_WORD_COLOR=#4da3ff
BUBBLE_REVEAL_WPM=170
BUBBLE_HOLD_REVEAL_WPM=480
